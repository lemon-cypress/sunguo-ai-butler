AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace_with_your_deepseek_key
DEEPSEEK_MODEL=deepseek-v4-flash
OPENAI_API_KEY=replace_with_your_key
OPENAI_MODEL=gpt-5.5
DEFAULT_CITY=北京-朝阳
WEATHER_LATITUDE=39.9219
WEATHER_LONGITUDE=116.4433
WEATHER_TIMEOUT_SECONDS=30
WEATHER_RETRIES=2
USE_REAL_WEATHER=true
TIMEZONE=Asia/Shanghai
OUTLOOK_FEATURE_ENABLED=false
USE_REAL_OUTLOOK=false
MICROSOFT_CLIENT_ID=replace_with_azure_app_client_id
MICROSOFT_TENANT=common
MICROSOFT_SCOPES=offline_access User.Read Calendars.ReadWrite
MICROSOFT_TOKEN_PATH=backend/data/ms_graph_token.json
LOCAL_SCHEDULE_PATH=backend/data/local_schedule.json
USE_REAL_MARKETS=true
MARKET_SYMBOLS_PATH=backend/data/market_symbols.json
USE_REAL_NEWS=true
NEWS_FEEDS_PATH=backend/data/news_feeds.json
NEWS_MAX_RECORDS_PER_QUERY=5
USE_REAL_THEMES=true
THEME_SYMBOLS_PATH=backend/data/theme_symbols.json
USE_REAL_COMPANIES=true
COMPANY_WATCHLIST_PATH=backend/data/company_watchlist.json
COMPANY_NEWS_MAX_RECORDS=2
COMPANY_MAX_COUNT=5
COMPANY_TIMEOUT_SECONDS=10
USER_PROFILE_PATH=backend/data/user_profile.json
